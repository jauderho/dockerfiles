FROM ubuntu:26.04@sha256:b7f48194d4d8b763a478a621cdc81c27be222ba2206ca3ca6bc42b49685f3d9e
#FROM python:3.14.2-slim-trixie@sha256:9b81fe9acff79e61affb44aaf3b6ff234392e8ca477cb86c9f7fd11732ce9b6a
#FROM python:3.14.6-alpine3.24@sha256:003970a263347645cd23d4f90929ad16ba7ce7d808ee4674ffcc93cb21cc289f

ARG BUILD_VERSION

COPY requirements.txt . 

#RUN pip install sslyze==${BUILD_VERSION}
# --no-deps: requirements.txt is a complete pinned closure (uv export);
# overrides sslyze's cryptography<47 cap. See pyproject.toml.
RUN pip3 install --no-cache-dir --no-deps -r requirements.txt

RUN rm -rf /usr/bin/pebble

ENTRYPOINT ["sslyze"]
CMD ["-h"]
