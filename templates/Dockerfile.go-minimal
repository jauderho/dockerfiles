#
# See https://medium.com/@chemidy/create-the-smallest-and-secured-golang-docker-image-based-on-scratch-4752223b7324
#
FROM ghcr.io/jauderho/golang:1.26.2-alpine3.23@sha256:5a7943df7a72f98b315b6213bb92abb7c8836a9911b86aefd8a16d8b35fd4cfc as build-env

WORKDIR /go/src/app
ADD . /go/src/app

RUN go get -d -v ./...

RUN go build -o /go/bin/app

FROM gcr.io/distroless/base-debian13@sha256:b0510424f0c7c1d6fdae75ef5c1d349fa72d312e96f69728fad6beb04755b8b4
COPY --from=build-env /go/bin/app /
CMD ["/app"]
