#
# See https://medium.com/@chemidy/create-the-smallest-and-secured-golang-docker-image-based-on-scratch-4752223b7324
#
FROM ghcr.io/jauderho/golang:1.26.4-alpine3.24@sha256:7509b4ee6bacbcde3b2b50e4ecdbbbd031b3eb4c67586fdea3f7c04f53915feb as build-env

WORKDIR /go/src/app
ADD . /go/src/app

RUN go get -d -v ./...

RUN go build -o /go/bin/app

FROM gcr.io/distroless/base-debian13@sha256:57c1e4c72feb5925c4763ae4f6bd2013ad3854f57eff5b60dd9acb1ce0abc66e
COPY --from=build-env /go/bin/app /
CMD ["/app"]
